{
  "name": "@peggyjs/coverage",
  "version": "2.0.5",
  "decription": "Generate better code coverage for Peggy grammars",
  "main": "lib/index.js",
  "type": "module",
  "files": [
    "lib/"
  ],
  "keywords": [
    "peggy,",
    "pegjs,",
    "coverage,",
    "test,",
    "unit,",
    "edgecase"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peggyjs/coverage.git"
  },
  "homepage": "https://github.com/peggyjs/coverage#readme",
  "bugs": {
    "url": "https://github.com/peggyjs/coverage/issues"
  },
  "scripts": {
    "build": "peggy -c peggy.config.js && tsc",
    "docs": "typedoc",
    "lint": "eslint .",
    "test": "c8 node --test test/*.test.js",
    "ci": "npm run build && npm run lint && npm run docs && npm run test"
  },
  "dependencies": {
    "peggy": "~5.1.0",
    "source-map": "~0.7.6"
  },
  "devDependencies": {
    "@peggyjs/eslint-config": "^6.0.13",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "superc8": "~12.3.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "typedoc@0.28.17>markdown-it": "14.1.1",
      "typedoc@0.28.17>minimatch": "9.0.9",
      "c8@11.0.0>yargs": "18.0.0"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
